from collections import Counter
import heapq


class Solution:
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        heap = []

        countr = Counter(nums)

        for item,frq in countr.items():
            heapq.heappush(heap,(frq,item))

        while len(heap) > k:
            heapq.heappop(heap)   

        return [j for i,j in heap]     
        